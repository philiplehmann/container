{
  "name": "tsc",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tsc/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@riwi/biomejs:lint"
    },
    "test": {
      "executor": "@riwi/bun:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {}
    },
    "typecheck": {
      "executor": "@riwi/tsc:typecheck"
    },
    "build": {
      "executor": "@riwi/bun:build",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/{projectRoot}",
        "entrypoints": ["{projectRoot}/src/index.ts", "{projectRoot}/src/executors/*/executor.ts"],
        "generatePackageJson": true,
        "tsConfig": "libs/tsc/tsconfig.lib.json",
        "assets": [
          "libs/tsc/package.json",
          "libs/tsc/executors.json",
          "libs/tsc/src/executors/**/*.json",
          "libs/tsc/README.md"
        ],
        "packages": "external"
      }
    }
  },
  "tags": []
}
