{
  "name": "bun",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/bun/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@riwi/biomejs:lint"
    },
    "test": {
      "executor": "@riwi/bun:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {}
    },
    "typecheck": {
      "executor": "@riwi/tsc:typecheck"
    },
    "build": {
      "executor": "@riwi/bun:build",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/{projectRoot}",
        "tsConfig": "libs/bun/tsconfig.lib.json",
        "entrypoints": ["{projectRoot}/src/index.ts", "{projectRoot}/src/executors/*/executor.ts"],
        "generatePackageJson": true,
        "assets": [
          "libs/bun/package.json",
          "libs/bun/executors.json",
          "libs/bun/src/executors/**/*.json",
          "libs/bun/README.md"
        ],
        "packages": "external"
      }
    }
  },
  "tags": []
}
