{
  "name": "nx",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/nx/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@riwi/biomejs:lint"
    },
    "test": {
      "executor": "@riwi/bun:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {}
    },
    "typecheck": {
      "executor": "@riwi/tsc:typecheck"
    },
    "build": {
      "executor": "@riwi/bun:build",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "entrypoints": ["{projectRoot}/src/index.ts", "{projectRoot}/src/executors/*/executor.ts"],
        "generatePackageJson": true,
        "tsConfig": "libs/nx/tsconfig.lib.json",
        "assets": ["libs/nx/package.json", "libs/nx/README.md"],
        "packages": "external"
      }
    }
  },
  "tags": []
}
