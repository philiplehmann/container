{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "esnext",
    "module": "NodeNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipDefaultLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "types": ["bun"],
    "baseUrl": "",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "paths": {
      "@riwi/binary/pdftk": ["./libs/binary/pdftk/src/index.ts"],
      "@riwi/binary/poppler": ["./libs/binary/poppler/src/index.ts"],
      "@riwi/binary/puppeteer": ["./libs/binary/puppeteer/src/index.ts"],
      "@riwi/binary/tesseract": ["./libs/binary/tesseract/src/index.ts"],
      "@riwi/binary/unoserver": ["./libs/binary/unoserver/src/index.ts"],
      "@riwi/binary/libreoffice": ["./libs/binary/libreoffice/src/index.ts"],
      "@riwi/binary/libreoffice-fs": ["./libs/binary/libreoffice-fs/src/index.ts"],
      "@riwi/biomejs": ["./libs/biomejs/src/index.ts"],
      "@riwi/bun": ["./libs/bun/src/index.ts"],
      "@riwi/docker": ["./libs/docker/src/index.ts"],
      "@riwi/node": ["./libs/node/src/index.ts"],
      "@riwi/nx": ["./libs/nx/src/index.ts"],
      "@riwi/helper": ["./libs/helper/src/index.ts"],
      "@riwi/http/body": ["./libs/http/body/src/index.ts"],
      "@riwi/http/error": ["./libs/http/error/src/index.ts"],
      "@riwi/http/multipart-form-data": ["./libs/http/multipart-form-data/src/index.ts"],
      "@riwi/http/route": ["./libs/http/route/src/index.ts"],
      "@riwi/http/server": ["./libs/http/server/src/index.ts"],
      "@riwi/http/validate": ["./libs/http/validate/src/index.ts"],
      "@riwi/stream": ["./libs/stream/src/index.ts"],
      "@riwi/test/bun": ["./libs/test/bun/src/index.ts"],
      "@riwi/test/node": ["./libs/test/node/src/index.ts"],
      "@riwi/test/request": ["./libs/test/request/src/index.ts"],
      "@riwi/test/server": ["./libs/test/server/src/index.ts"],
      "@riwi/tsc": ["./libs/tsc/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
