{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/playwright:playwright": {
      "cache": true,
      "inputs": ["default"]
    },
    "@riwi/biomejs:lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json", "{projectRoot}/biome.json"]
    },
    "@riwi/tsc:typecheck": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/tsconfig.base.json"]
    },
    "@riwi/node:test": {
      "cache": true,
      "inputs": ["default"]
    },
    "@riwi/bun:test": {
      "cache": true,
      "inputs": ["default"]
    },
    "@riwi/bun:build": {
      "cache": true,
      "inputs": ["default"]
    },
    "@riwi/docker:test": {
      "cache": false,
      "inputs": ["default", "{projectRoot}/Dockerfile", "{projectRoot}/.env.docker"]
    },
    "@riwi/docker:build": {
      "cache": false,
      "inputs": ["default", "{projectRoot}/Dockerfile", "{projectRoot}/.env.docker"]
    },
    "@riwi/docker:run": {
      "cache": false,
      "inputs": ["default", "{projectRoot}/Dockerfile", "{projectRoot}/.env.docker"]
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s",
      "!{projectRoot}/biome.json"
    ],
    "sharedGlobals": ["{workspaceRoot}/bun.lock", "{workspaceRoot}/.github/**/*"]
  },
  "cli": {
    "packageManager": "bun"
  },
  "defaultBase": "main",
  "parallel": 8,
  "release": {
    "projects": ["bun", "biomejs", "tsc", "node", "docker", "helper"],
    "conventionalCommits": {},
    "changelog": {
      "projectChangelogs": true
    }
  },
  "plugins": [
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    }
  ]
}
